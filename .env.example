# Copy to .env and fill in your keys (all optional)
# FINNHUB_API_KEY=your_key_from_finnhub.io
# POLYGON_API_KEY=optional

# LLM backend (auto-detected: Ollama local first, then Anthropic cloud)
# Ollama: no key needed, just run: ollama pull llama3.1:8b
# Anthropic: uncomment and set your key for cloud fallback
# ANTHROPIC_API_KEY=sk-ant-...
